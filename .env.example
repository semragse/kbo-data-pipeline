# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# --- MongoDB ---
MONGO_URI=mongodb://admin:admin123@localhost:27017/
MONGO_DB=kbo_bronze

# --- Données KBO ---
# Chemin vers le dossier contenant les CSV KBO Open Data
KBO_DIR=.

# --- Scraping NBB CBSO ---
# Clé gratuite à obtenir sur https://developer.cbso.nbb.be
# Créer un compte, souscrire au produit de consultation
NBB_API_KEY=

# Années à scraper (séparées par des virgules)
NBB_YEARS=2021,2022,2023,2024,2025

# --- Stockage dépôts NBB ---
# Dossier local pour les PDFs/JSON téléchargés
NBB_OUTPUT_DIR=tmp/nbb_deposits

# --- Scraping eJustice ---
# Dossier local pour les publications légales (JSON)
EJUSTICE_OUTPUT_DIR=tmp/ejustice
